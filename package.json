{
  "name": "@freehour/supabase-llamaindex",
  "private": false,
  "displayName": "Supabase-LlamaIndex",
  "description": "Integration package for using LlamaIndex embedding service with Supabase",
  "version": "1.1.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freehour/supabase-llamaindex.git"
  },
  "scripts": {
    "lint": "eslint ./lib --ext ts",
    "build": "bun run lint && tsc && vite build",
    "postinstall": "bun ./scripts/copy-supabase-assets.js"
  },
  "files": [
    "dist",
    "supabase/migrations/0001_supabase_llamaindex.sql",
    "supabase/schemas/supabase-llamaindex",
    "scripts/copy-supabase-assets.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@freehour/supabase-core": "^1.5.2",
    "@llamaindex/supabase": "^0.1.24",
    "@supabase/storage-js": "^2.100.0",
    "@supabase/supabase-js": "2.99.3",
    "llamaindex": "^0.12.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-js": "2.10.1",
    "@stylistic/eslint-plugin-plus": "2.10.1",
    "@stylistic/eslint-plugin-ts": "2.10.1",
    "@typescript-eslint/eslint-plugin": "8.14.0",
    "@typescript-eslint/parser": "8.14.0",
    "ajv": "^8.18.0",
    "bun-types": "^1.3.11",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import-x": "4.4.3",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "supabase": "^2.84.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "trustedDependencies": [
    "@freehour/supabase-core"
  ]
}